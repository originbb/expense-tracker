PORT=10000
JWT_SECRET=super-secret-key-for-local-testing
# Turso 연동 정보 (비워둘 경우 로컬에 local.db SQLite 파일이 자동으로 생성되어 테스트 가능합니다)
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# 비밀번호 재설정 메일 발송용 SMTP (비워두면 인증 코드가 서버 콘솔에 출력됩니다)
# 예) Gmail: SMTP_HOST=smtp.gmail.com, SMTP_PORT=465, SMTP_SECURE=true,
#     SMTP_USER=내계정@gmail.com, SMTP_PASS=앱비밀번호
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
