PORT=10000
JWT_SECRET=super-secret-key-for-local-testing
# Turso 연동 정보 (비워둘 경우 로컬에 local.db SQLite 파일이 자동으로 생성되어 테스트 가능합니다)
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=
# Google Cloud Vision API (없으면 Tesseract.js로 자동 폴백)
# Google Cloud Console > API 및 서비스 > 사용자 인증 정보 > API 키
GOOGLE_VISION_API_KEY=

# 비밀번호 재설정 메일 발송용 Brevo (HTTP API, 비워두면 인증 코드가 서버 콘솔에 출력됩니다)
# 1) https://www.brevo.com 무료 가입
# 2) 발신자 이메일 인증 (Senders → 이메일로 받은 OTP 입력, 도메인 불필요)
# 3) SMTP & API → API Keys 에서 키 발급 → 아래 BREVO_API_KEY 에 입력
BREVO_API_KEY=
# 발신자 주소: 위 2)에서 인증한 이메일과 반드시 동일해야 합니다.
MAIL_FROM=
# 발신자 표시 이름 (선택, 기본값 "경비 전표")
MAIL_FROM_NAME=
